# Copy to .env and fill in. Used at build time for Vite.
# Get a key: https://api.census.gov/data/key_signup.html
# For the LIVE SITE: either set VITE_CENSUS_API_KEY here and add your production domain to the key's "Allowed Referrers", or deploy the /api/census-zip proxy and set CENSUS_API_KEY in your host's env (e.g. Vercel).
VITE_CENSUS_API_KEY=your_census_api_key_here

# Optional: set to "false" to skip the proxy and always call Census directly (need allowed referrer for production).
# VITE_USE_CENSUS_PROXY=true

# Optional: if your API proxy is at a different path (e.g. Netlify function), set base URL here.
# VITE_CENSUS_PROXY_URL=https://your-site.com/api
